# ─────────────────────────────────────────────────────────────────────────────
# AI Asset Discovery — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_discovery
DATABASE_SYNC_URL=postgresql://postgres:postgres@db:5432/ai_discovery

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars
# JWT expiry in minutes (default: 480 = 8 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── MinIO (S3-compatible storage) ─────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_MAX_FILE_SIZE_MB=500

# ── App / CORS ─────────────────────────────────────────────────────────────────
DEBUG=false
# Comma-separated or JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Anthropic Claude — Sprint 3 (ADR-009) ────────────────────────────────────
# Required for LLM-based asset enrichment (detection engine)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─────────────────────────────────────────────────────────────────────────────
# CONNECTOR CREDENTIALS — never store real credentials here!
# These are examples only. Configure per workspace via the UI.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sprint 2 — Azure Connector ────────────────────────────────────────────────
# Provided per-connector in the UI:
#   tenant_id, client_id, client_secret, subscription_id

# ── Sprint 5 — Salesforce Connector ──────────────────────────────────────────
# Requires a Connected App with Client Credentials Flow enabled.
# Provided per-connector in the UI:
#   instance_url  – https://mycompany.my.salesforce.com
#   client_id     – Connected App Consumer Key
#   client_secret – Connected App Consumer Secret

# ── Sprint 5 — ServiceNow Connector ──────────────────────────────────────────
# Requires a service account with read access to AI tables.
# Provided per-connector in the UI:
#   instance_url – https://mycompany.service-now.com
#   username     – Service account username
#   password     – Service account password

# ── Sprint 5 — SAP AI Core Connector ─────────────────────────────────────────
# Requires SAP BTP Service Key (XSUAA).
# Provided per-connector in the UI:
#   token_url       – BTP XSUAA token URL
#   client_id       – BTP clientid
#   client_secret   – BTP clientsecret
#   ai_core_api_url – SAP AI Core API base URL
#   resource_group  – SAP AI Core resource group (default: "default")

# ── Sprint 5 — Dynamics 365 Connector ────────────────────────────────────────
# Requires Azure AD App Registration with Dynamics CRM user_impersonation.
# Provided per-connector in the UI:
#   tenant_id       – Azure AD tenant ID
#   client_id       – App registration client ID
#   client_secret   – App registration client secret
#   environment_url – https://myorg.crm.dynamics.com

# ── Sprint 6 — Microsoft 365 Connector ───────────────────────────────────────
# Requires Azure AD App Registration with these Application permissions:
#   Reports.Read.All · Organization.Read.All · TeamsApp.Read.All · Application.Read.All
# Provided per-connector in the UI:
#   tenant_id     – Azure AD tenant ID
#   client_id     – App registration client ID
#   client_secret – App registration client secret
#   include_beta  – "true" to enable SharePoint Syntex + Copilot Studio discovery
